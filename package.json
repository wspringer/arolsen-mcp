{
  "name": "arolsen-mcp",
  "version": "0.1.1",
  "description": "MCP server for searching the Arolsen Archives",
  "type": "module",
  "license": "MIT",
  "author": "Wilfred Springer <wilfred@eastpole.nl>",
  "homepage": "https://github.com/wspringer/arolsen-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wspringer/arolsen-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/wspringer/arolsen-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "arolsen",
    "archives",
    "genealogy",
    "claude",
    "claude-code"
  ],
  "bin": {
    "arolsen-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "vitest run --config vitest.smoke.config.ts",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "biome check src test",
    "format": "biome check --write src test",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}